# =============================================================
# Mobile LLM Benchmark Suite — Environment Variables
# =============================================================

# OpenRouter API key — required for real benchmarks via OpenRouter
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# HuggingFace API token — required for HF Inference API models
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# ----- API / network settings -----

# OpenRouter API base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# HuggingFace Inference API base URL
HF_INFERENCE_BASE_URL=https://api-inference.huggingface.co/v1

# HTTP request timeout in seconds (default: 60)
REQUEST_TIMEOUT=60

# Max retries per model call (default: 3)
MAX_RETRIES=3

# Base wait (seconds) between retries — actual wait uses exponential backoff + jitter (default: 1.0)
RETRY_BASE_WAIT=1.0

# Extra wait (seconds) when a 429 rate-limit error is detected (default: 10.0)
RATE_LIMIT_WAIT=10.0

# ----- Benchmark settings -----

# Force mock mode even when API keys are present ("true" / "false")
MOCK_MODE=false

# Number of samples per benchmark in demo mode (default: 50)
DEMO_N_SAMPLES=50

# Random seed for reproducibility in mock mode (default: 42)
MOCK_SEED=42

# ----- Model overrides (optional — defaults are latest model IDs) -----
# Uncomment and set to override a specific model ID

# MODEL_PHI4_MINI=microsoft/phi-4-mini-instruct
# MODEL_GEMMA3_1B=google/gemma-3-1b-it
# MODEL_GEMMA3_4B=google/gemma-3-4b-it
# MODEL_QWEN25_15B=Qwen/Qwen2.5-1.5B-Instruct
# MODEL_QWEN25_3B=Qwen/Qwen2.5-3B-Instruct
# MODEL_SMOLLM2=HuggingFaceTB/SmolLM2-1.7B-Instruct
# MODEL_QWEN3_06B=Qwen/Qwen3-0.6B
# MODEL_LLAMA32_1B=meta-llama/llama-3.2-1b-instruct
# MODEL_LLAMA32_3B=meta-llama/Llama-3.2-3B-Instruct
# MODEL_QWEN3_17B=Qwen/Qwen3-1.7B

# ----- Output & UI settings -----

# Output directory for all benchmark artifacts (default: outputs)
OUTPUT_DIR=outputs

# Gradio server host (default: 0.0.0.0)
GRADIO_HOST=0.0.0.0

# Gradio server port (default: 7860)
GRADIO_PORT=7860

# Logging level (DEBUG, INFO, WARNING, ERROR) — default: INFO
LOG_LEVEL=INFO

# OpenRouter HTTP-Referer header (used for OpenRouter attribution)
OPENROUTER_REFERER=https://github.com/dakshjain-1616/mobile-llm-benchmark-suite
